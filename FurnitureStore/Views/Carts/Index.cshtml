@model IEnumerable<FurnitureStore.Models.Cart>

@{
    ViewData["Title"] = "Index";
    decimal totalPrice = Model.Sum(i => i.Items.UnitPrice);
}

<div class="container section-padding">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="display-5 fw-bold">Your Cart</h1>
            <p class="text-muted">Review your selected items.</p>
        </div>
        <a asp-controller="Items" asp-action="Index" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left me-2"></i>Continue Shopping
        </a>
    </div>

    <div class="row g-4">
        @foreach (var cartItem in Model) {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card h-100 shadow-sm border-0">
                    <div class="position-relative">
                        <div class="item-carousel" data-item-id="@cartItem.Items.Items_ID">
                            @{
                                var images = cartItem.Items.Images != null ? cartItem.Items.Images.ToList() : new List<FurnitureStore.Models.tblImage>();
                                if (images.Any() && images[0].image != null)
                                {
                                    <div class="carousel-inner position-relative">
                                        @for (int i = 0; i < images.Count; i++)
                                        {
                                            var base64 = Convert.ToBase64String(images[i].image);
                                            var imgSrc = String.Format("data:image/jpg;base64,{0}", base64);
                                            <div class="carousel-item @(i == 0 ? "active" : "")" data-index="@i">
                                                <img src="@imgSrc" class="card-img-top" alt="@cartItem.Items.Name" style="height: 250px; object-fit: cover;">
                                            </div>
                                        }

                                        <!-- Navigation Arrows -->
                                        @if (images.Count > 1)
                                        {
                                            <button class="carousel-control-prev" type="button" data-bs-target=".item-carousel" data-bs-slide="prev">
                                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                                <span class="visually-hidden">Previous</span>
                                            </button>
                                            <button class="carousel-control-next" type="button" data-bs-target=".item-carousel" data-bs-slide="next">
                                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                                <span class="visually-hidden">Next</span>
                                            </button>
                                        }
                                    </div>

                                    <!-- Indicators/Dots -->
                                    @if (images.Count > 1)
                                    {
                                        <div class="carousel-indicators position-absolute bottom-0" style="z-index: 2;">
                                            @for (int i = 0; i < images.Count; i++)
                                            {
                                                <button type="button" data-bs-target=".item-carousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")" aria-label="Slide @(i + 1)"></button>
                                            }
                                        </div>
                                    }
                                }
                                else
                                {
                                    <img src="https://via.placeholder.com/400x300?text=No+Image" class="card-img-top" alt="No Image" style="height: 250px; object-fit: cover;">
                                }
                            }
                        </div>
                        <div class="position-absolute top-0 end-0 p-2">
                            <span class="badge bg-white text-dark shadow-sm">$@cartItem.Items.UnitPrice</span>
                        </div>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-truncate">@cartItem.Items.Name</h5>
                        <p class="card-text text-muted small text-truncate" style="max-height: 3em; overflow: hidden;">@cartItem.Items.Description</p>
                        
                        <div class="mt-auto d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@cartItem.Cart_id" class="btn btn-sm btn-outline-info flex-grow-1">
                                Details
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger flex-grow-1" data-bs-toggle="modal" data-bs-target="#deleteModal" data-cart-id="@cartItem.Cart_id">
                                Remove
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.Any())
    {
        <div class="d-flex justify-content-end mt-5">
            <div class="card border-0 shadow-sm p-4 bg-light" style="min-width: 300px;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="h5 mb-0">Total:</span>
                    <span class="h4 mb-0 fw-bold text-primary">$@totalPrice</span>
                </div>
                <button type="button" class="btn btn-success w-100 py-2" data-bs-toggle="modal" data-bs-target="#buyModal">
                    Proceed to Checkout
                </button>
            </div>
        </div>
    }
    
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="fas fa-shopping-cart fa-4x text-muted"></i>
            </div>
            <h3>Your cart is empty</h3>
            <p class="text-muted">Looks like you haven't added any items yet.</p>
            <a asp-controller="Items" asp-action="Index" class="btn btn-primary mt-3">Start Shopping</a>
        </div>
    }
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title" id="deleteModalLabel">Confirm Removal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to remove this item from your cart?
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="Delete" method="post" id="deleteForm">
                    <input type="hidden" name="id" id="cartIdToDelete" />
                    <button type="submit" class="btn btn-danger">Remove</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    var deleteModal = document.getElementById('deleteModal');
    deleteModal.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget;
        var cartId = button.getAttribute('data-cart-id');
        var input = document.getElementById('cartIdToDelete');
        input.value = cartId;
    });
</script>

<!-- Buy Confirmation Modal -->
<div class="modal fade" id="buyModal" tabindex="-1" aria-labelledby="buyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title" id="buyModalLabel">Confirm Purchase</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info border-0 d-flex align-items-center mb-4">
                    <i class="fas fa-info-circle me-2"></i>
                    <div>Please review your items before confirming.</div>
                </div>
                
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0 rounded-start ps-3">Item</th>
                                <th class="border-0 text-end rounded-end pe-3">Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <div class="fw-bold">@item.Items.Name</div>
                                        <small class="text-muted">@item.Items.Description</small>
                                    </td>
                                    <td class="text-end pe-3">$@item.Items.UnitPrice</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="border-top">
                            <tr>
                                <td class="ps-3 pt-3 text-end fw-bold">Total Amount:</td>
                                <td class="pe-3 pt-3 text-end fw-bold text-primary fs-5">$@totalPrice</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="ProcessOrder" method="post">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="fas fa-check me-2"></i>Confirm Purchase
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize carousels
            $('.item-carousel').each(function() {
                const carousel = $(this);
                const items = carousel.find('.carousel-item');
                const indicators = carousel.find('.carousel-indicators button');

                if (items.length <= 1) return;

                // Previous button
                carousel.find('.carousel-control-prev').click(function() {
                    const activeItem = carousel.find('.carousel-item.active');
                    const activeIndex = parseInt(activeItem.data('index'));
                    const prevIndex = activeIndex === 0 ? items.length - 1 : activeIndex - 1;

                    switchSlide(activeIndex, prevIndex);
                });

                // Next button
                carousel.find('.carousel-control-next').click(function() {
                    const activeItem = carousel.find('.carousel-item.active');
                    const activeIndex = parseInt(activeItem.data('index'));
                    const nextIndex = activeIndex === items.length - 1 ? 0 : activeIndex + 1;

                    switchSlide(activeIndex, nextIndex);
                });

                // Indicator clicks
                indicators.click(function() {
                    const targetIndex = parseInt($(this).data('bs-slide-to'));
                    const activeItem = carousel.find('.carousel-item.active');
                    const activeIndex = parseInt(activeItem.data('index'));

                    if (activeIndex !== targetIndex) {
                        switchSlide(activeIndex, targetIndex);
                    }
                });

                function switchSlide(fromIndex, toIndex) {
                    // Hide current active
                    items.removeClass('active');
                    indicators.removeClass('active').attr('aria-current', 'false');

                    // Show new active
                    items.eq(toIndex).addClass('active');
                    indicators.eq(toIndex).addClass('active').attr('aria-current', 'true');
                }
            });
        });
    </script>
}

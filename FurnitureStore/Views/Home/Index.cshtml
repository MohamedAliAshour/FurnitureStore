@model IEnumerable<FurnitureStore.Models.Item>
@{
    ViewData["Title"] = "Home Page";
}

<!-- Hero Section -->
<div class="hero-section position-relative text-white mb-5" style="background-image: url('/images/hero.png'); background-size: cover; background-position: center; height: 80vh; display: flex; align-items: center;">
    <div class="overlay position-absolute top-0 start-0 w-100 h-100" style="background: rgba(0,0,0,0.4);"></div>
    <div class="container position-relative fade-in">
        <div class="row">
            <div class="col-lg-8">
                <h1 class="display-3 fw-bold mb-4 text-white">Elevate Your Living Space</h1>
                <p class="lead mb-5 fs-4">Discover our curated collection of premium furniture designed for modern life. Comfort meets elegance.</p>
                <a asp-controller="Items" asp-action="Index" class="btn btn-primary btn-lg px-5 py-3">Shop Now</a>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="container mb-5">
    <div class="row text-center g-4">
        <div class="col-md-4">
            <div class="p-4 border rounded-3 bg-light h-100">
                <i class="fas fa-shipping-fast fa-3x text-gold mb-3"></i>
                <h4>Fast Shipping</h4>
                <p class="text-muted">Get your furniture delivered safely and quickly to your doorstep.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 border rounded-3 bg-light h-100">
                <i class="fas fa-medal fa-3x text-gold mb-3"></i>
                <h4>Premium Quality</h4>
                <p class="text-muted">Crafted with the finest materials to ensure durability and style.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 border rounded-3 bg-light h-100">
                <i class="fas fa-headset fa-3x text-gold mb-3"></i>
                <h4>24/7 Support</h4>
                <p class="text-muted">Our dedicated team is here to assist you with any questions.</p>
            </div>
        </div>
    </div>
</div>

<!-- Featured Products Section -->
<div class="container section-padding">
    <div class="text-center mb-5">
        <h2 class="display-5 mb-3">Featured Collection</h2>
        <p class="text-muted">Handpicked items just for you</p>
    </div>
    
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="item-carousel" data-item-id="@item.Items_ID">
                            @{
                                var images = item.Images != null ? item.Images.ToList() : new List<FurnitureStore.Models.tblImage>();
                                if (images.Any() && images[0].image != null)
                                {
                                    <div class="carousel-inner position-relative">
                                        @for (int i = 0; i < images.Count; i++)
                                        {
                                            var base64 = Convert.ToBase64String(images[i].image);
                                            var imgSrc = String.Format("data:image/jpg;base64,{0}", base64);
                                            <div class="carousel-item @(i == 0 ? "active" : "")" data-index="@i">
                                                <img src="@imgSrc" class="card-img-top" alt="@item.Name" style="height: 250px; object-fit: cover;">
                                            </div>
                                        }

                                        <!-- Navigation Arrows -->
                                        @if (images.Count > 1)
                                        {
                                            <button class="carousel-control-prev" type="button" data-bs-target=".item-carousel" data-bs-slide="prev">
                                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                                <span class="visually-hidden">Previous</span>
                                            </button>
                                            <button class="carousel-control-next" type="button" data-bs-target=".item-carousel" data-bs-slide="next">
                                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                                <span class="visually-hidden">Next</span>
                                            </button>
                                        }
                                    </div>

                                    <!-- Indicators/Dots -->
                                    @if (images.Count > 1)
                                    {
                                        <div class="carousel-indicators position-absolute bottom-0" style="z-index: 2;">
                                            @for (int i = 0; i < images.Count; i++)
                                            {
                                                <button type="button" data-bs-target=".item-carousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")" aria-label="Slide @(i + 1)"></button>
                                            }
                                        </div>
                                    }
                                }
                                else
                                {
                                    <img src="https://via.placeholder.com/400x300?text=No+Image" class="card-img-top" alt="No Image" style="height: 250px; object-fit: cover;">
                                }
                            }
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@item.Name</h5>
                            <p class="card-text text-muted text-truncate">@item.Description</p>
                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <span class="h5 mb-0 text-gold">$@item.UnitPrice</span>
                                <a asp-controller="Items" asp-action="Details" asp-route-id="@item.Items_ID" class="btn btn-outline-primary btn-sm">View Details</a>
                            </div>
                        </div>
                    </div> 
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center">
                <p class="text-muted">No featured items available at the moment.</p>
            </div>
        }
    </div>
    <div class="text-center mt-5">
        <a asp-controller="Items" asp-action="Index" class="btn btn-outline-primary px-4">View All Products</a>
    </div>
</div>

<!-- About Preview Section -->
<div class="bg-light section-padding">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6 mb-4 mb-md-0">
                <img src="https://images.unsplash.com/photo-1556228453-efd6c1ff04f6?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80" class="img-fluid rounded shadow" alt="Interior Design">
            </div>
            <div class="col-md-6 ps-md-5">
                <h2 class="mb-4">Designed for Modern Living</h2>
                <p class="text-muted mb-4">We believe that furniture should be more than just functional. It should be an expression of your style and a source of comfort. Our collections are curated to bring the best of modern design into your home.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize carousels
            $('.item-carousel').each(function() {
                const carousel = $(this);
                const items = carousel.find('.carousel-item');
                const indicators = carousel.find('.carousel-indicators button');

                if (items.length <= 1) return;

                // Previous button
                carousel.find('.carousel-control-prev').click(function() {
                    const activeItem = carousel.find('.carousel-item.active');
                    const activeIndex = parseInt(activeItem.data('index'));
                    const prevIndex = activeIndex === 0 ? items.length - 1 : activeIndex - 1;

                    switchSlide(activeIndex, prevIndex);
                });

                // Next button
                carousel.find('.carousel-control-next').click(function() {
                    const activeItem = carousel.find('.carousel-item.active');
                    const activeIndex = parseInt(activeItem.data('index'));
                    const nextIndex = activeIndex === items.length - 1 ? 0 : activeIndex + 1;

                    switchSlide(activeIndex, nextIndex);
                });

                // Indicator clicks
                indicators.click(function() {
                    const targetIndex = parseInt($(this).data('bs-slide-to'));
                    const activeItem = carousel.find('.carousel-item.active');
                    const activeIndex = parseInt(activeItem.data('index'));

                    if (activeIndex !== targetIndex) {
                        switchSlide(activeIndex, targetIndex);
                    }
                });

                function switchSlide(fromIndex, toIndex) {
                    // Hide current active
                    items.removeClass('active');
                    indicators.removeClass('active').attr('aria-current', 'false');

                    // Show new active
                    items.eq(toIndex).addClass('active');
                    indicators.eq(toIndex).addClass('active').attr('aria-current', 'true');
                }
            });
        });
    </script>
}
